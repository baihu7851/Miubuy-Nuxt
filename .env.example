# REST API 基礎網址
NUXT_PUBLIC_API_BASE=https://miubuy.rocket-coding.com

# SignalR Hub 完整 URL
NUXT_PUBLIC_SIGNALR_HUB=https://miubuy.rocket-coding.com/signalr

# 圖片上傳 API URL
NUXT_PUBLIC_UPLOAD_URL=https://miubuy.rocket-coding.com/api/UpLoadFile
