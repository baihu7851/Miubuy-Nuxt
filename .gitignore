# miubuy — .gitignore
#☆.｡.:*・ﾟ ☆.｡.:*・ﾟ ☆.｡.:*・ﾟ ☆.｡.:*・ﾟ ☆

#☆=========== 依賴套件 ===========☆
node_modules/

#☆=========== Nuxt 建置輸出 ===========☆
.nuxt/
.output/
dist/

#☆=========== Nitro ===========☆
.nitro/

#☆=========== 快取 ===========☆
.cache/
.npm/
.eslintcache

#☆=========== 環境變數（保留範本） ===========☆
.env
.env.local
.env.*.local
# ☆ .env.example 保留，讓其他人知道需要哪些變數
!.env.example

#☆=========== 鎖定檔（擇一使用） ===========☆
# ☆ 本專案使用 npm，保留 package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

#☆=========== Log 檔 ===========☆
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

#☆=========== 測試 / 覆蓋率 ===========☆
coverage/
.nyc_output/

#☆=========== 編輯器：VS Code ===========☆
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix

#☆=========== 作業系統：Windows ===========☆
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

#☆=========== 作業系統：macOS ===========☆
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd